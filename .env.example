# Airtable Config
# Get your token at: https://airtable.com/create/tokens
# Scope needed: data.records:write
VITE_AIRTABLE_TOKEN=your_personal_access_token_here

# Get this from your Airtable base URL: airtable.com/appXXXXXX/...
VITE_AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Name of your table in Airtable (default: Email Generator)
VITE_AIRTABLE_TABLE=Email Generator
